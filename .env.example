# ============================================================
#  eFootball Friend Match Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git!
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP

# Your Telegram user ID (integer). Get from @userinfobot
OWNER_ID=123456789

# Your bot's public URL (HTTPS required for webhooks)
# Examples:
#   Render:  https://my-bot.onrender.com
#   Railway: https://my-bot.up.railway.app
#   VPS:     https://mybotdomain.com
WEBHOOK_HOST=https://your-domain.com

# ── OPTIONAL ─────────────────────────────────────────────────
BOT_NAME=eFootball Match Bot
BOT_USERNAME=efootball_match_bot
DEVELOPER_NAME=YourName
DEVELOPER_CONTACT=@YourUsername

# Port (default 5000; Render/Railway set this automatically)
PORT=5000

# SQLite database file path
DB_PATH=database/efootball.db

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
